q=0.8,application/signed-exchange;v=b3;q=0.7";s:10:"user-agent";s:111:"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36";s:25:"upgrade-insecure-requests";s:1:"1";s:12:"content-type";s:33:"application/x-www-form-urlencoded";s:6:"origin";s:28:"http://admin.videogear.local";s:13:"cache-control";s:9:"max-age=0";s:14:"content-length";s:4:"2832";s:10:"connection";s:10:"keep-alive";s:4:"host";s:21:"admin.videogear.local";}s:15:"responseHeaders";a:6:{s:7:"Expires";s:29:"Thu, 19 Nov 1981 08:52:00 GMT";s:13:"Cache-Control";s:35:"no-store, no-cache, must-revalidate";s:6:"Pragma";s:8:"no-cache";s:8:"Location";s:48:"http://admin.videogear.local/product/update?id=1";s:12:"Content-Type";s:24:"text/html; charset=UTF-8";s:10:"Set-Cookie";s:277:"_identity-backend=c802e88535e0bbf6bdc95af17c0e934fee23676d5412eb79413621f1ba2b8458a%3A2%3A%7Bi%3A0%3Bs%3A17%3A%22_identity-backend%22%3Bi%3A1%3Bs%3A16%3A%22%5B1%2Cnull%2C2592000%5D%22%3B%7D; expires=Thu, 02-Apr-2026 17:10:53 GMT; Max-Age=2592000; path=/; HttpOnly; SameSite=Lax";}s:5:"route";s:14:"product/update";s:6:"action";s:45:"common\components\actions\UpdateAction::run()";s:12:"actionParams";a:1:{s:2:"id";s:1:"1";}s:7:"general";a:5:{s:6:"method";s:4:"POST";s:6:"isAjax";b:0;s:6:"isPjax";b:0;s:7:"isFlash";b:0;s:18:"isSecureConnection";b:0;}s:11:"requestBody";a:3:{s:12:"Content Type";s:33:"application/x-www-form-urlencoded";s:3:"Raw";s:2832:"_csrf-backend=LP2afibrmu-Uwb2l3uTKtIp3c3DMNIPNcoNsHQqq_dR9r9ghR7_4jeyXheLstvji3iNDAvlW2_gasCFTbvO2gA%3D%3D&ProductForm%5Bname%5D=Canon+EOS+Cinema+C300+MK+III+EU-V2+EMEA&ProductForm%5Bcategory_id%5D=1&ProductForm%5Bsku%5D=3795C019AA&ProductForm%5Bprice%5D=1200.00&ProductForm%5Bquantity%5D=5&ProductForm%5Bshort_description%5D=The+Canon+EU-V2+Expansion+Unit+2+mounts+onto+your+C500+Mark+II+camera+and+provides+a+V-mount+battery+mount+for+power+as+well+as+ports+that+expand+the+capabilities+of+your+camera.&ProductForm%5Bdescription%5D=%3Cp%3EThe+Canon+EU-V2+Expansion+Unit+2+mounts+onto+your+C500+Mark+II+camera+and+provides+a+V-mount+battery+mount+for+power+as+well+as+ports+that+expand+the+capabilities+of+your+camera.+The+expansion+unit+adds+five+ports%3A+Genlock%2FSync+Out%2C+Remote+B+%28RS-422%29%2C+Ethernet%2C+DC+Out+%2824V%2C+2A%29%2C+and+a+lens+control+port.+This+unit+expands+your+C500+Mark+II+for+work+as+a+full-sized+production+camera%2C+adding+two+3-pin+XLR+connectors+for+audio+input.+The+V-mount+battery+plate+incorporates+a+D-Tap+output+for+powering+accessories.%3C%2Fp%3E%0D%0A%3Cp%3ECreate+cinema-quality+productions+with+the+Canon+EOS+C300+Mark+III+Digital+Cinema+Camera%2C+which+features+a+Super+35mm+Dual+Gain+Output+sensor+with+up+to+16+stops+of+high+dynamic+range+capability+for+superior+HDR+recording+and+low+noise.+The+EF+lens+mount+offers+compatibility+not+only+with+Canon%27s+existing+broad+range+of+DSLR+lenses+but+also+with+their+line+of+EF-mount+cinema+prime%2C+zooms%2C+and+even+2.0+and+1.33+anamorphic+lenses.+The+mount+is+also+interchangeable+with+a+separately+available+PL+mount+by+the+end+user.%3C%2Fp%3E%0D%0A%3Ch2%3ECanon+EU-V2+Expansion+unit+2%3C%2Fh2%3E%0D%0A%3Cul%3E%0D%0A%3Cli%3EV-Mount+Battery+Plate%3C%2Fli%3E%0D%0A%3Cli%3EAdds+Two+XLR+Audio+Connectors%3C%2Fli%3E%0D%0A%3Cli%3EAdds+Genlock%2FSync+Out%3C%2Fli%3E%0D%0A%3Cli%3EAdds+Remote+B+%28RS-422%29%3C%2Fli%3E%0D%0A%3Cli%3EAdds+Ethernet+Port%3C%2Fli%3E%0D%0A%3Cli%3E24+VDC+out+Port%3C%2Fli%3E%0D%0A%3Cli%3ELens+Power+and+Control+Port%3C%2Fli%3E%0D%0A%3C%2Ful%3E%0D%0A%3Ch2%3ECanon+EOS+C300+Mark+III+Digital+Cinema+Camera%3C%2Fh2%3E%0D%0A%3Cul%3E%0D%0A%3Cli%3ESuper+35mm+Dual+Gain+Output+%28DGO%29+Sensor%3C%2Fli%3E%0D%0A%3Cli%3E4K+120p%2C+2K+Crop+180p+HDR%3C%2Fli%3E%0D%0A%3Cli%3ECinema+RAW+Light+and+XF-AVC+H.264+Codec%3C%2Fli%3E%0D%0A%3Cli%3EEF+Lens+Mount%2C+DIG%21C+DV7+Image+Processor%3C%2Fli%3E%0D%0A%3Cli%3EDual+Pixel+CMOS+AF+and+Face+Detection%3C%2Fli%3E%0D%0A%3Cli%3ELM-V2+4.3%22+LCD+Touchscreen+Monitor%3C%2Fli%3E%0D%0A%3Cli%3E12G-SDI+and+4-Channel+Audio+Recording%3C%2Fli%3E%0D%0A%3Cli%3E2+x+CFexpress+Slots%2C+Canon+Log2+and+3%3C%2Fli%3E%0D%0A%3Cli%3EElectronic+Image+Stabilization%3C%2Fli%3E%0D%0A%3Cli%3EProxy+Recording%2C+Anamorphic+Lens+Support%3C%2Fli%3E%0D%0A%3C%2Ful%3E&ProductForm%5BproductImageIds%5D=%5B9%2C7%2C8%5D";s:7:"Decoded";a:2:{s:13:"_csrf-backend";s:88:"LP2afibrmu-Uwb2l3uTKtIp3c3DMNIPNcoNsHQqq_dR9r9ghR7_4jeyXheLstvji3iNDAvlW2_gasCFTbvO2gA==";s:11:"ProductForm";a:8:{s:4:"name";s:39:"Canon EOS Cinema C300 MK III EU-V2 EMEA";s:11:"category_id";s:1:"1";s:3:"sku";s:10:"3795C019AA";s:5:"price";s:7:"1200.00";s:8:"quantity";s:1:"5";s:17:"short_description";s:178:"The Canon EU-V2 Expansion Unit 2 mounts onto your C500 Mark II camera and provides a V-mount battery mount for power as well as ports that expand the capabilities of your camera.";s:11:"description";s:1869:"<p>The Canon EU-V2 Expansion Unit 2 mounts onto your C500 Mark II camera and provides a V-mount battery mount for power as well as ports that expand the capabilities of your camera. The expansion unit adds five ports: Genlock/Sync Out, Remote B (RS-422), Ethernet, DC Out (24V, 2A), and a lens control port. This unit expands your C500 Mark II for work as a full-sized production camera, adding two 3-pin XLR connectors for audio input. The V-mount battery plate incorporates a D-Tap output for powering accessories.</p>
<p>Create cinema-quality productions with the Canon EOS C300 Mark III Digital Cinema Camera, which features a Super 35mm Dual Gain Output sensor with up to 16 stops of high dynamic range capability for superior HDR recording and low noise. The EF lens mount offers compatibility not only with Canon's existing broad range of DSLR lenses but also with their line of EF-mount cinema prime, zooms, and even 2.0 and 1.33 anamorphic lenses. The mount is also interchangeable with a separately available PL mount by the end user.</p>
<h2>Canon EU-V2 Expansion unit 2</h2>
<ul>
<li>V-Mount Battery Plate</li>
<li>Adds Two XLR Audio Connectors</li>
<li>Adds Genlock/Sync Out</li>
<li>Adds Remote B (RS-422)</li>
<li>Adds Ethernet Port</li>
<li>24 VDC out Port</li>
<li>Lens Power and Control Port</li>
</ul>
<h2>Canon EOS C300 Mark III Digital Cinema Camera</h2>
<ul>
<li>Super 35mm Dual Gain Output (DGO) Sensor</li>
<li>4K 120p, 2K Crop 180p HDR</li>
<li>Cinema RAW Light and XF-AVC H.264 Codec</li>
<li>EF Lens Mount, DIG!C DV7 Image Processor</li>
<li>Dual Pixel CMOS AF and Face Detection</li>
<li>LM-V2 4.3" LCD Touchscreen Monitor</li>
<li>12G-SDI and 4-Channel Audio Recording</li>
<li>2 x CFexpress Slots, Canon Log2 and 3</li>
<li>Electronic Image Stabilization</li>
<li>Proxy Recording, Anamorphic Lens Support</li>
