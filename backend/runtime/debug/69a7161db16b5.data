end/web";s:12:"DOCUMENT_URI";s:10:"/index.php";s:11:"REQUEST_URI";s:20:"/product/update?id=1";s:11:"SCRIPT_NAME";s:10:"/index.php";s:14:"CONTENT_LENGTH";s:4:"2832";s:12:"CONTENT_TYPE";s:33:"application/x-www-form-urlencoded";s:14:"REQUEST_METHOD";s:4:"POST";s:12:"QUERY_STRING";s:4:"id=1";s:9:"PHP_VALUE";s:51:"error_log=/var/log/nginx/application_php_errors.log";s:15:"SCRIPT_FILENAME";s:34:"/application/backend/web/index.php";s:9:"FCGI_ROLE";s:9:"RESPONDER";s:8:"PHP_SELF";s:10:"/index.php";s:18:"REQUEST_TIME_FLOAT";d:1772557853.719191;s:12:"REQUEST_TIME";i:1772557853;}s:3:"GET";a:1:{s:2:"id";s:1:"1";}s:4:"POST";a:2:{s:13:"_csrf-backend";s:88:"LP2afibrmu-Uwb2l3uTKtIp3c3DMNIPNcoNsHQqq_dR9r9ghR7_4jeyXheLstvji3iNDAvlW2_gasCFTbvO2gA==";s:11:"ProductForm";a:8:{s:4:"name";s:39:"Canon EOS Cinema C300 MK III EU-V2 EMEA";s:11:"category_id";s:1:"1";s:3:"sku";s:10:"3795C019AA";s:5:"price";s:7:"1200.00";s:8:"quantity";s:1:"5";s:17:"short_description";s:178:"The Canon EU-V2 Expansion Unit 2 mounts onto your C500 Mark II camera and provides a V-mount battery mount for power as well as ports that expand the capabilities of your camera.";s:11:"description";s:1869:"<p>The Canon EU-V2 Expansion Unit 2 mounts onto your C500 Mark II camera and provides a V-mount battery mount for power as well as ports that expand the capabilities of your camera. The expansion unit adds five ports: Genlock/Sync Out, Remote B (RS-422), Ethernet, DC Out (24V, 2A), and a lens control port. This unit expands your C500 Mark II for work as a full-sized production camera, adding two 3-pin XLR connectors for audio input. The V-mount battery plate incorporates a D-Tap output for powering accessories.</p>
<p>Create cinema-quality productions with the Canon EOS C300 Mark III Digital Cinema Camera, which features a Super 35mm Dual Gain Output sensor with up to 16 stops of high dynamic range capability for superior HDR recording and low noise. The EF lens mount offers compatibility not only with Canon's existing broad range of DSLR lenses but also with their line of EF-mount cinema prime, zooms, and even 2.0 and 1.33 anamorphic lenses. The mount is also interchangeable with a separately available PL mount by the end user.</p>
<h2>Canon EU-V2 Expansion unit 2</h2>
<ul>
<li>V-Mount Battery Plate</li>
<li>Adds Two XLR Audio Connectors</li>
<li>Adds Genlock/Sync Out</li>
<li>Adds Remote B (RS-422)</li>
<li>Adds Ethernet Port</li>
<li>24 VDC out Port</li>
<li>Lens Power and Control Port</li>
</ul>
<h2>Canon EOS C300 Mark III Digital Cinema Camera</h2>
<ul>
<li>Super 35mm Dual Gain Output (DGO) Sensor</li>
<li>4K 120p, 2K Crop 180p HDR</li>
<li>Cinema RAW Light and XF-AVC H.264 Codec</li>
<li>EF Lens Mount, DIG!C DV7 Image Processor</li>
<li>Dual Pixel CMOS AF and Face Detection</li>
<li>LM-V2 4.3" LCD Touchscreen Monitor</li>
<li>12G-SDI and 4-Channel Audio Recording</li>
<li>2 x CFexpress Slots, Canon Log2 and 3</li>
<li>Electronic Image Stabilization</li>
<li>Proxy Recording, Anamorphic Lens Support</li>
</ul>";s:15:"productImageIds";s:7:"[9,7,8]";}}s:6:"COOKIE";a:3:{s:16:"advanced-backend";s:26:"227rp7dap5fs0mgjqck636o6b0";s:17:"_identity-backend";s:127:"c802e88535e0bbf6bdc95af17c0e934fee23676d5412eb79413621f1ba2b8458a:2:{i:0;s:17:"_identity-backend";i:1;s:16:"[1,null,2592000]";}";s:13:"_csrf-backend";s:139:"5a9716b35457b47bd37b417be714989370ad67811df8441a2aadcd8f36265668a:2:{i:0;s:13:"_csrf-backend";i:1;s:32:"QRB_aTbbxV8G2R2VTT0r5bX5h3MNdYKT";}";}s:5:"FILES";a:0:{}s:7:"SESSION";a:5:{s:7:"__flash";a:1:{s:7:"success";i:-1;}s:11:"__returnUrl";s:29:"http://admin.videogear.local/";s:4:"__id";i:1;s:9:"__authKey";N;s:7:"success";s:29:"Product successfully updated!";}}";s:4:"user";s:3412:"a:5:{s:2:"id";i:1;s:8:"identity";a:21:{s:2:"id";s:1:"1";s:5:"email";s:28:"'marinamandic1999@yahoo.com'";s:8:"username";s:7:"'admin'";s:13:"password_hash";s:62:"'$2y$13$uwbmE6LJ5qPG/HyCbC3KluEAD6geaDhNHeo5byon3EKIZcthQm5y2'";s:20:"password_reset_token";s:4:"null";s:18:"verification_token";s:4:"null";s:8:"auth_key";s:4:"null";s:6:"status";s:2:"10";s:8:"is_staff";s:1:"1";s:10:"first_name";s:8:"'Marina'";s:9:"last_name";s:9:"'Mandić'";s:7:"address";s:15:"'Njegoševa 37'";s:4:"city";s:19:"'Istočno Sarajevo'";s:7:"country";s:4:"'BA'";s:3:"zip";s:5:"71123";s:5:"phone";s:14:"'+38766638949'";s:10:"created_at";s:10:"1761511731";s:10:"created_by";s:4:"null";s:10:"updated_at";s:4:"null";s:10:"updated_by";s:4:"null";s:10:"is_deleted";s:1:"0";}s:10:"attributes";a:21:{i:0;a:2:{s:9:"attribute";s:2:"id";s:5:"label";s:2:"ID";}i:1;a:2:{s:9:"attribute";s:5:"email";s:5:"label";s:5:"Email";}i:2;a:2:{s:9:"attribute";s:8:"username";s:5:"label";s:8:"Username";}i:3;a:2:{s:9:"attribute";s:13:"password_hash";s:5:"label";s:13:"Password Hash";}i:4;a:2:{s:9:"attribute";s:20:"password_reset_token";s:5:"label";s:20:"Password Reset Token";}i:5;a:2:{s:9:"attribute";s:18:"verification_token";s:5:"label";s:18:"Verification Token";}i:6;a:2:{s:9:"attribute";s:8:"auth_key";s:5:"label";s:8:"Auth Key";}i:7;a:2:{s:9:"attribute";s: